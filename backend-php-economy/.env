# CodeIgniter4 Environment Configuration
# All values here are OVERRIDDEN by Render environment variable injection in production
# !! DO NOT COMMIT THE REAL CREDENTIALS — set them in Render dashboard !!

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname    = YOUR_AIVEN_HOST
database.default.database    = defaultdb
database.default.username    = avnadmin
database.default.password    = YOUR_AIVEN_PASSWORD
database.default.port        = YOUR_AIVEN_PORT
database.default.DBDriver    = MySQLi
database.default.DBPrefix    =
database.default.charset     = utf8mb4
database.default.DBCollat    = utf8mb4_general_ci

#--------------------------------------------------------------------
# APP BASE URL (must be a valid URL for CI4)
#--------------------------------------------------------------------
app.baseURL = 'https://elev8-php-economy-1f5f.onrender.com/'
