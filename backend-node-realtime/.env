# Node.js Realtime Server — Environment Variables
# Set these in the Render dashboard (Environment tab), do NOT commit real secrets

# The PHP Economy API running on Render
PHP_API_URL=https://elev8-php-economy-1f5f.onrender.com/api/v1

# Internal service-to-service API key (must match EconomyController.php check)
SERVICE_API_KEY=development_internal_key

# Port (Render injects this automatically, but set here as fallback)
PORT=3001
